{
  "name": "realtor-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "RealtorAI — Zillow→video agent + iMessage lead agent + realtor dashboard",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace client run build",
    "vercel-build": "npm --workspace client run build",
    "start": "npm --workspace server run start",
    "migrate": "node server/scripts/migrate.js",
    "deploy:butterbase": "node server/scripts/deploy-butterbase.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "spectrum-ts": "^0.4.0"
  }
}
